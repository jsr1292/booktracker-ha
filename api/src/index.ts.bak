import express, { type Request, type Response } from 'express';
import cors from 'cors';
import Database from 'better-sqlite3';
import { readFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';
import { existsSync, mkdirSync } from 'fs';

const __dirname = dirname(fileURLToPath(import.meta.url));
const ROOT = join(__dirname, '..', '..');
const CLIENT_DIST = join(ROOT, 'client', 'dist');
const DB_PATH = join(__dirname, '..', 'data', 'books.db');

const app = express();
app.use(cors());
app.use(express.json());

// ── Database ────────────────────────────────────────────────────────
mkdirSync(join(__dirname, '..', 'data'), { recursive: true });

const db = new Database(DB_PATH);
db.pragma('journal_mode = WAL');

db.exec(`
  CREATE TABLE IF NOT EXISTS books (
    id           INTEGER PRIMARY KEY AUTOINCREMENT,
    title        TEXT    NOT NULL,
    author       TEXT,
    status       TEXT    NOT NULL DEFAULT 'reading',
    rating       INTEGER,
    pages        INTEGER,
    genre        TEXT,
    language     TEXT,
    cover_url    TEXT,
    description  TEXT,
    date_started TEXT,
    date_finished TEXT,
    planned_date TEXT,
    notes        TEXT,
    created_at   TEXT    NOT NULL DEFAULT (datetime('now')),
    updated_at   TEXT    NOT NULL DEFAULT (datetime('now'))
  )
`);

// ── Helpers ──────────────────────────────────────────────────────
interface Book {
  id: number; title: string; author: string | null; status: string;
  rating: number | null; pages: number | null; genre: string | null;
  language: string | null; cover_url: string | null; description: string | null;
  date_started: string | null; date_finished: string | null;
  planned_date: string | null; notes: string | null;
  created_at: string; updated_at: string;
}
interface BookRow extends Book {}

function toBook(row: BookRow): Book { return row; }

// ── Routes ───────────────────────────────────────────────────────

// GET /api/stats
app.get('/api/stats', (_req: Request, res: Response) => {
  try {
    const all = db.prepare('SELECT * FROM books').all() as BookRow[];
    const total = all.length;
    const finished = all.filter(b => b.status === 'finished');
    const reading = all.filter(b => b.status === 'reading');
    const rated = finished.filter(b => b.rating != null);

    const avgPages = finished.length
      ? Math.round(finished.reduce((s, b) => s + (b.pages ?? 0), 0) / finished.length)
      : 0;
    const totalPages = finished.reduce((s, b) => s + (b.pages ?? 0), 0);
    const avgRating = rated.length
      ? Math.round(rated.reduce((s, b) => s + (b.rating ?? 0), 0) / rated.length * 10) / 10
      : 0;

    // Current streak: consecutive months with at least 1 finished book
    const monthCounts = new Map<string, number>();
    for (const b of finished) {
      if (!b.date_finished) continue;
      const m = b.date_finished.substring(0, 7);
      monthCounts.set(m, (monthCounts.get(m) ?? 0) + 1);
    }
    const currentStreak = monthCounts.size;

    const globalAvgRating = finished.length
      ? Math.round(finished.reduce((s, b) => s + (b.rating ?? 0), 0) / finished.length * 10) / 10
      : 0;

    res.json({
      total_books: total, total_finished: finished.length, currently_reading: reading.length,
      finished, total_pages: totalPages, avg_pages: avgPages,
      global_avg_rating: globalAvgRating, current_streak: currentStreak,
      avg_days_to_finish: null,
    });
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// GET /api/books
app.get('/api/books', (req: Request, res: Response) => {
  try {
    const rows = db.prepare('SELECT * FROM books ORDER BY created_at DESC').all() as BookRow[];
    res.json(rows.map(toBook));
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// POST /api/books
app.post('/api/books', (req: Request, res: Response) => {
  try {
    const { title, author, status, rating, pages, genre, language, cover_url, description, date_started, date_finished, planned_date, notes } = req.body;
    if (!title) { res.status(400).json({ error: 'title is required' }); return; }

    const validStatuses = ['reading', 'finished', 'abandoned', 'planned'];
    const s = validStatuses.includes(status) ? status : 'finished';

    const stmt = db.prepare(`
      INSERT INTO books (title, author, status, rating, pages, genre, language, cover_url, description, date_started, date_finished, planned_date, notes)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `);
    const result = stmt.run(title, author ?? null, s, rating ?? null, pages ?? null, genre ?? null, language ?? null, cover_url ?? null, description ?? null, date_started ?? null, date_finished ?? null, planned_date ?? null, notes ?? null);
    const newBook = db.prepare('SELECT * FROM books WHERE id = ?').get(result.lastInsertRowid) as BookRow;
    res.status(201).json(toBook(newBook));
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// PUT /api/books/:id
app.put('/api/books/:id', (req: Request, res: Response) => {
  try {
    const { title, author, status, rating, pages, genre, language, cover_url, description, date_started, date_finished, planned_date, notes } = req.body;
    const { id } = req.params;

    const validStatuses = ['reading', 'finished', 'abandoned', 'planned'];
    const s = validStatuses.includes(status) ? status : 'finished';

    const stmt = db.prepare(`
      UPDATE books SET title=?, author=?, status=?, rating=?, pages=?, genre=?, language=?,
      cover_url=?, description=?, date_started=?, date_finished=?, planned_date=?, notes=?,
      updated_at=datetime('now') WHERE id=?
    `);
    stmt.run(title, author ?? null, s, rating ?? null, pages ?? null, genre ?? null, language ?? null, cover_url ?? null, description ?? null, date_started ?? null, date_finished ?? null, planned_date ?? null, notes ?? null, id);
    const updated = db.prepare('SELECT * FROM books WHERE id=?').get(id) as BookRow | undefined;
    if (!updated) { res.status(404).json({ error: 'Book not found' }); return; }
    res.json(toBook(updated));
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// DELETE /api/books/:id
app.delete('/api/books/:id', (req: Request, res: Response) => {
  try {
    db.prepare('DELETE FROM books WHERE id=?').run(req.params.id);
    res.json({ success: true });
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// GET /api/preferences
app.get('/api/preferences', (_req: Request, res: Response) => {
  try {
    const books = db.prepare("SELECT * FROM books WHERE status = 'finished'").all() as BookRow[];

    const genreMap = new Map<string, number>();
    for (const b of books) { if (b.genre) genreMap.set(b.genre, (genreMap.get(b.genre) ?? 0) + 1); }
    const topGenres = [...genreMap.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5)
      .map(([genre, count]) => ({ genre, count }));

    const withPages = books.filter(b => b.pages != null);
    const avgPages = withPages.length > 0
      ? Math.round(withPages.reduce((s, b) => s + (b.pages ?? 0), 0) / withPages.length)
      : 300;
    const lengthBucket = avgPages < 250 ? 'short' : avgPages < 400 ? 'medium' : 'long';

    const authorMap = new Map<string, { total: number; count: number }>();
    for (const b of books) {
      if (b.author && b.rating != null) {
        const existing = authorMap.get(b.author);
        if (existing) { existing.total += b.rating; existing.count += 1; }
        else authorMap.set(b.author, { total: b.rating, count: 1 });
      }
    }
    const topAuthors = [...authorMap.entries()]
      .filter(([, v]) => v.count >= 1)
      .map(([author, v]) => ({ author, avgRating: Math.round((v.total / v.count) * 10) / 10 }))
      .sort((a, b) => b.avgRating - a.avgRating)
      .slice(0, 5);

    res.json({ topGenres, avgPages, lengthBucket, topAuthors, totalRated: books.filter(b => b.rating != null).length });
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// GET /api/recommendations
app.get('/api/recommendations', async (req: Request, res: Response) => {
  try {
    const { genre, maxPages, minRating, author, q, exclude } = req.query;

    let searchQ = '';
    if (q) searchQ = String(q);
    else if (author) { searchQ = `inauthor:${author}`; if (genre) searchQ += `+subject:${genre}`; }
    else if (genre) searchQ = `subject:${genre}`;
    else searchQ = 'subject:fiction';

    const url = `https://www.googleapis.com/books/v1/volumes?q=${encodeURIComponent(searchQ)}&maxResults=20&printType=books&langRestrict=en`;
    const resp = await fetch(url);
    if (!resp.ok) throw new Error(`Google Books API error: ${resp.status}`);
    const data = await resp.json() as any;

    if (!data.items?.length) return res.json([]);

    const excludeIds = new Set<string>();
    if (exclude) {
      const owned = db.prepare('SELECT title, author FROM books').all() as BookRow[];
      owned.forEach(b => excludeIds.add(`${b.title}|${b.author}`.toLowerCase()));
    }

    const LANG_MAP: Record<string, string> = {
      en: 'English', es: 'Spanish', fr: 'French', de: 'German',
      it: 'Italian', pt: 'Portuguese', ja: 'Japanese', zh: 'Chinese',
    };

    const recs = data.items
      .map((item: any) => {
        const v = item.volumeInfo;
        const title = v.title || '';
        const authors = (v.authors || []).join(', ');
        const key = `${title}|${authors}`.toLowerCase();
        if (exclude && excludeIds.has(key)) return null;
        if (maxPages && v.pageCount && v.pageCount > Number(maxPages)) return null;
        if (minRating && (!v.averageRating || v.averageRating < Number(minRating))) return null;
        return {
          googleId: item.id, title, author: authors,
          coverUrl: v.imageLinks?.thumbnail?.replace('http:', 'https:') || null,
          pages: v.pageCount || null, genre: (v.categories || [])[0] || null,
          rating: v.averageRating || null, description: v.description || null,
          year: v.publishedDate ? v.publishedDate.substring(0, 4) : null,
          language: v.language ? (LANG_MAP[v.language] || v.language) : null,
        };
      })
      .filter(Boolean);

    res.json(recs.slice(0, 12));
  } catch (err: unknown) {
    res.status(500).json({ error: err instanceof Error ? err.message : 'Unknown error' });
  }
});

// ── Static files (SPA fallback) ──────────────────────────────────
if (existsSync(CLIENT_DIST)) {
  app.use(express.static(CLIENT_DIST));
  app.get('*', (_req: Request, res: Response) => {
    const index = join(CLIENT_DIST, 'index.html');
    if (existsSync(index)) res.sendFile(index);
    else res.status(404).send('Not found');
  });
}

// ── Start ────────────────────────────────────────────────────────
const PORT = parseInt(process.env.PORT ?? '3443');
const HOST = '0.0.0.0';
app.listen(PORT, HOST, () => {
  console.log(`Book Tracker API running on ${HOST}:${PORT}`);
});
